# Server
PORT=3001
UPLOAD_DIR=./data/uploads

# JWT / auth
JWT_SECRET=change-me-in-prod

# Razorpay — TEST KEYS ONLY. Server refuses to boot if RAZORPAY_KEY_ID
# starts with "rzp_live_". Leave empty to run in mock-order mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional — HMAC secret from the Razorpay dashboard webhook settings.
RAZORPAY_WEBHOOK_SECRET=

# Zoho Mail SMTP — used for OTPs, password-reset links and payment receipts.
# ZOHO_PASS must be the 16-char app-specific password from Zoho > My Account >
# Security > App Passwords, NOT your login password.
ZOHO_USER=
ZOHO_PASS=
ZOHO_HOST=smtp.zoho.in
ZOHO_PORT=465
ZOHO_FROM_NAME=The Foundation Room

# Where reset / receipt links should point.
FRONTEND_URL=http://localhost:3001

# ── Wasabi object storage ──────────────────────────────────────────────────
# Set WASABI_ENABLED=true to route all uploads (videos, recordings, submissions,
# sheet music, avatars, message attachments, resources) to your Wasabi bucket.
# When false or unset, files fall back to local disk under UPLOAD_DIR.
WASABI_ENABLED=false
WASABI_BUCKET=
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=

# Wasabi region — must match the region you created the bucket in.
# Common regions: us-east-1, us-east-2, us-central-1, us-west-1, eu-central-1,
# eu-west-1, eu-west-2, ap-northeast-1, ap-southeast-1, ap-southeast-2
WASABI_REGION=us-east-1

# Leave blank to auto-derive from region, or override for custom endpoints.
# Standard pattern: https://s3.<region>.wasabisys.com
WASABI_ENDPOINT=
