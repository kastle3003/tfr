# Server
PORT=3001
UPLOAD_DIR=./data/uploads

# Database path — on Render set this to the persistent disk path:
#   DB_PATH=/var/data/archive.db
# Without it, the DB defaults to ./data/archive.db which is ephemeral on Render
# (wiped on every deploy — logins stop working after each push).
DB_PATH=

# JWT / auth — use a long random string in production, NEVER the default below
JWT_SECRET=change-me-in-prod

# Razorpay — TEST KEYS ONLY. Server refuses to boot if RAZORPAY_KEY_ID
# starts with "rzp_live_". Leave empty to run in mock-order mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional — HMAC secret from the Razorpay dashboard webhook settings.
RAZORPAY_WEBHOOK_SECRET=

# ── ZeptoMail SMTP (recommended for production) ───────────────────────────────
# ZEPTO_TOKEN  = the API token from ZeptoMail dashboard (Mail Agents > SMTP)
# ZEPTO_SENDER = the verified "From" email address (e.g. noreply@yourdomain.com)
ZEPTO_TOKEN=
ZEPTO_SENDER=
# ZEPTO_HOST defaults to smtp.zeptomail.in, port to 587 — only override if needed
# ZEPTO_HOST=smtp.zeptomail.in
# ZEPTO_PORT=587
ZEPTO_FROM_NAME=The Foundation Room

# ── Zoho Mail SMTP (legacy / alternative) ─────────────────────────────────────
# ZOHO_PASS must be the 16-char app-specific password from Zoho > My Account >
# Security > App Passwords, NOT your login password.
ZOHO_USER=
ZOHO_PASS=
ZOHO_HOST=smtp.zoho.in
ZOHO_PORT=465

# ── Public URL ────────────────────────────────────────────────────────────────
# FRONTEND_URL  — primary URL used in password-reset / email links.
# ALLOWED_ORIGINS — comma-separated list of frontend origins allowed by CORS.
#   Add every domain that needs to call the API (admin panel, student portal,
#   custom domain, Render preview URL, localhost, etc.).
#   Leave empty to allow all origins (fine for local dev, avoid in production).
#
# Example (multiple origins):
#   ALLOWED_ORIGINS=https://app.tfrplay.com,https://admin.tfrplay.com,http://localhost:3001
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=

# ── Wasabi object storage ──────────────────────────────────────────────────
# Set WASABI_ENABLED=true to route all uploads (videos, recordings, submissions,
# sheet music, avatars, message attachments, resources) to your Wasabi bucket.
# When false or unset, files fall back to local disk under UPLOAD_DIR.
WASABI_ENABLED=false
WASABI_BUCKET=
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=

# Wasabi region — must match the region you created the bucket in.
# Common regions: us-east-1, us-east-2, us-central-1, us-west-1, eu-central-1,
# eu-west-1, eu-west-2, ap-northeast-1, ap-southeast-1, ap-southeast-2
WASABI_REGION=us-east-1

# Leave blank to auto-derive from region, or override for custom endpoints.
# Standard pattern: https://s3.<region>.wasabisys.com
WASABI_ENDPOINT=
